# Copy to .env.dev / .env.staging / .env.prod and fill in. Never commit real values.

# --- Core ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+psycopg://agentgate:agentgate@localhost:5432/agentgate

# --- Queue ---
REDIS_URL=redis://localhost:6379/0

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Connectors ---
GITHUB_TOKEN=
TELEGRAM_BOT_TOKEN=
STRIPE_API_KEY=
